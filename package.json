{
  "name": "ag-lyrics-syncer",
  "homepage": "https://crimsonCarnival.github.io/lrc-editor/",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "postdeploy": "git checkout main",
    "postinstall": "node -e \"const fs=require('fs'),s='node_modules/kuromoji/dict',d='public/dict';if(!fs.existsSync(d))fs.mkdirSync(d,{recursive:true});fs.readdirSync(s).forEach(f=>fs.copyFileSync(s+'/'+f,d+'/'+f))\" && npx esbuild node_modules/kuromoji/src/kuromoji.js --bundle --format=iife --global-name=kuromoji --outfile=public/kuromoji.iife.js --platform=browser \"--alias:path=./src/utils/path-shim.js\" --minify"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/noto-serif-jp": "^5.2.9",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^25.10.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "kuromoji": "^0.1.2",
    "lucide-react": "^1.7.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.0",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "wavesurfer.js": "^7.12.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.1",
    "vite-tsconfig-paths": "^6.1.1",
    "wrangler": "^4.79.0"
  }
}
